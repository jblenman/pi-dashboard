# Copy to secrets.env and fill in. Loaded by the systemd services (web + collector).
# secrets.env is gitignored -- never commit the real password.

# Pi-hole v6 app password: Pi-hole UI > Settings > API > App Password.
# Leave the password blank to run the dashboard with Pi-hole mock data.
PIDASH_PIHOLE_URL=http://127.0.0.1
PIDASH_PIHOLE_APP_PASSWORD=

# Optional: pin a specific Ookla server id (otherwise it auto-picks the best).
# PIDASH_SPEEDTEST_SERVER_ID=
